# Local development uses Docker Compose Postgres (see docker-compose.yml).
# In production, set DATABASE_URL via Parameter Store / instance env (see ARCHITECTURE.md §6).
DATABASE_URL=postgresql://seqtek:seqtek@localhost:5433/seqtek_dev

# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace_me_with_a_32_byte_random_hex_value

# Content Security Policy mode: enforce | report-only | off
# See INTEGRATIONS.md §8 "Rollout mechanism" — dev=enforce, staging=report-only,
# production=enforce after the staging soak passes the promote-to-enforce checklist.
# Default is report-only so violations surface without breaking the page.
CSP_MODE=report-only

# OAuth — Google Workspace SSO for /admin (D-14, ADR 0002, spec 001).
# Get values from the SEQTEK Google Cloud Console (OAuth 2.0 Client Credentials).
# Local dev: paste your dev client below. Staging/prod read from AWS Parameter Store
# (/seqtek/website/{env}/google_client_{id,secret}) — see contracts/env-vars.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
