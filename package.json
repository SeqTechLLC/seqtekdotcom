{
  "name": "seqtek-website",
  "version": "0.3.0",
  "description": "SEQTEK marketing website — Next.js + Payload CMS",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "check:overrides": "node tools/check-stale-overrides/check-stale-overrides.mjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3100",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --port 3100",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ingest:photos": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/ingest-photos/index.ts",
    "ingest:curated": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/ingest-photos/ingest-curated.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload:seed": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-seed/index.ts",
    "prepare": "husky",
    "pretest:e2e": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/e2e/provision-schema.ts",
    "seed:showcase": "cross-env NODE_OPTIONS=--no-deprecation tsx src/payload/seed/showcase/index.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" PAYLOAD_DISABLE_PUSH=true playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:lhci": "lhci autorun --config=.lighthouserc.cjs",
    "typecheck": "tsc --noEmit",
    "visual:capture": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.visual.config.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,mts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1056.0",
    "@payloadcms/db-postgres": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@payloadcms/storage-s3": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "jose": "6.2.3",
    "next": "^16.2.6",
    "payload": "^3.85.0",
    "postcss": "^8.4.49",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.58.2",
    "@testcontainers/postgresql": "12.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/heic-convert": "^2.1.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "heic-convert": "^2.1.0",
    "husky": "^9.1.7",
    "jsdom": "28.0.0",
    "lint-staged": "^17.0.4",
    "prettier": "^3.4.2",
    "testcontainers": "12.0.0",
    "tsx": "4.22.4",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "overrides": {
    "tsx": "$tsx",
    "drizzle-kit": {
      "esbuild": "^0.28.1"
    },
    "payload": {
      "ws": "^8.21.0",
      "undici": "^7.28.0"
    },
    "happy-dom": {
      "ws": "^8.21.0"
    }
  },
  "_overridesNotes": {
    "_doc": "Why each security `overrides` entry exists and when it can go. Keyed by the overridden package name. Advisory IDs are NOT hand-maintained here — `npm run check:overrides` reads them live from `npm audit` and flags any override that is no longer load-bearing. A note here with no matching `overrides` entry is reported as 'pending' (e.g. queued for an unmerged PR), not an error.",
    "esbuild": "Pinned (under drizzle-kit) to clear the transitive esbuild dev-server advisory that failed the production audit gate in PR #52. Remove once drizzle-kit's dependency tree resolves esbuild to a fixed version on its own — run `npm run check:overrides` to confirm.",
    "ws": "Pinned to ^8.21.0 (under payload and happy-dom) to clear the transitive ws advisory pulled in via @lexical/headless. Remove once payload and happy-dom resolve ws to a non-vulnerable version on their own. NOTE: the `ws` override itself lands on main with PR #66 (feat/010); until then this note is reported as 'pending' by `npm run check:overrides`.",
    "undici": "Pinned to ^7.28.0 (under payload) to clear the transitive undici high-severity advisories GHSA-vmh5-mc38-953g + GHSA-pr7r-676h-xcf6 (vulnerable 7.0.0–7.27.2). Remove once payload resolves undici to >=7.28.0 on its own — run `npm run check:overrides` to confirm."
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
