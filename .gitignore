# CDK
infra/cdk.out/
infra/.cdk.staging/

# Payload generated types — committed so CI typecheck (which has no Postgres
# and can't run `payload generate:types`) can resolve them. Regenerate
# locally with `npm run generate:types` after any collection schema change
# and commit the diff alongside the schema change.

# Scratch workspace (template scaffolds, throwaway experiments)
.scratch/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/tests/e2e/screenshots/
# Visual showcase captures — regenerated locally via `npm run visual:capture`.
# Keep out of the repo to avoid binary churn on every block change.
/tests/e2e/visual/screenshots/

# spec-kit local cache (extension catalog cache + install registry)
.specify/extensions/.cache/
.specify/extensions/.registry

